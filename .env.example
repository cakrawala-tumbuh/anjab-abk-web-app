# Konfigurasi web app (12-factor). Salin ke `.env.local` lalu sesuaikan.

# URL backend (publik — ter-inline ke bundle browser)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# URL backend dari sisi server (gunakan nama service Docker saat deploy)
# API_BASE_URL_INTERNAL=http://anjab-abk-backend:8000

# Auth.js — wajib diisi sebelum login berfungsi
# Generate dengan: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Authentik OIDC (server-only — JANGAN prefix NEXT_PUBLIC_)
# Issuer: URL aplikasi OIDC Authentik, mis. https://auth.example.com/application/o/anjab-abk/
AUTHENTIK_ISSUER=https://auth.example.com/application/o/anjab-abk/
# Client ID public client (PKCE, tanpa client_secret)
AUTHENTIK_CLIENT_ID=your-client-id-here

# URL aplikasi (untuk redirect URI; dipakai Auth.js)
# AUTH_URL=https://app.example.com

# Widget helpdesk Chatwoot "Butuh Bantuan?" (opsional — kosongkan untuk menonaktifkan)
# Base URL instance Chatwoot yayasan
# NEXT_PUBLIC_CHATWOOT_BASE_URL=https://chat.example.sch.id
# Website inbox token (Chatwoot → Inboxes → Add Inbox → Website)
# NEXT_PUBLIC_CHATWOOT_WEBSITE_TOKEN=your-website-inbox-token-here
